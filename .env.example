# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real keys.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=genesis_dev

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose ONE provider. Comment out the others.

# Option A: Azure OpenAI (production / demo)
AI_API_KEY=your-azure-openai-api-key
AI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/gpt-4o
AI_CHAT_MODEL=gpt-4o
AI_IMAGE_MODEL=dall-e-3

# Option B: Groq (free tier, fast, good for local dev)
# AI_API_KEY=your-groq-api-key
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_CHAT_MODEL=llama-3.1-70b-versatile
# AI_IMAGE_MODEL=          # Groq has no image gen — logo will use a placeholder

# Option C: Ollama via Docker (fully local, no cost)
# Start with: docker compose --profile local-ai up -d
# Pull model: docker exec genesis-ollama ollama pull llama3.2
AI_API_KEY=ollama
AI_BASE_URL=http://ollama:11434/v1
AI_CHAT_MODEL=llama3.2
AI_IMAGE_MODEL=
